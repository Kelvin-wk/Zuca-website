# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Application URL (e.g., https://your-app.vercel.app or http://localhost:3000)
APP_URL=http://localhost:3000

# Firebase Configuration (Optional if using firebase-applet-config.json)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_DATABASE_ID=your_database_id

# Firebase Service Account (JSON string, required for some production environments)
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'
